DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional but recommended when you later use pooled Neon URLs for runtime.
# Keep DATABASE_URL as pooled and DIRECT_URL as the direct Neon connection for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Optional demo passwords for prisma seed.
SEED_OWNER_PASSWORD="Owner@Sewa123"
SEED_ADMIN_PASSWORD="Admin@Sewa123"
SEED_FINANCE_PASSWORD="Finance@Sewa123"
SEED_OPERASIONAL_PASSWORD="Operasional@Sewa123"
